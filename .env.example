# Antigravity OS Local Secrets
# Rename this file to .env and add your actual API key.
# Do NOT commit your actual .env file to Git!

# ---------------------------------------------------------
# UNIVERSAL LLM ROUTING (Works with OpenRouter, Groq, NIM)
# ---------------------------------------------------------
# The engine will automatically pick the right key based on the LLM_BASE_URL you uncomment.

OPENROUTER_API_KEY=your_openrouter_api_key_here
GROQ_API_KEY=your_groq_api_key_here
NIM_API_KEY=your_nim_api_key_here

# --- CHOOSE YOUR BRAIN (Uncomment ONE block below) ---

# Example 1: OpenRouter (Access Gemini Pro via OpenRouter)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemini-1.5-pro

# Example 2: Groq
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Example 3: NVIDIA NIM
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama3-70b-instruct
